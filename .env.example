# Supabase · backend del proyecto (BD + auth + storage).
#
# Copia este archivo a `.env.local` y rellena con los valores reales del
# proyecto Supabase. NO subas `.env.local` al repo (ya está en .gitignore).
#
# Vercel: configura las mismas vars en el dashboard del proyecto Vercel
# para que la build de producción tenga acceso. Solo `VITE_*` se exponen
# al cliente · `SUPABASE_SERVICE_ROLE_KEY` y `SUPABASE_DB_URL` son
# secretas y nunca se deben usar en código de cliente.

# ─── Variables que usa el cliente (frontend) ──────────────────────────
# URL pública del proyecto (visible en Settings → API).
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# anon public key · diseñada para ir en código cliente. RLS protege los
# datos · esta key sin sesión solo permite acceso a tablas públicas.
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Variables solo para administración (NO usar en frontend) ─────────
# service_role key · bypassa RLS · solo para scripts de seed/migración.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Connection string Postgres (Settings → Database → Connection string).
# Formato: postgresql://postgres:<password>@<host>:5432/postgres
SUPABASE_DB_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.xxxxxxxxxxxxxxxxxxxx.supabase.co:5432/postgres
